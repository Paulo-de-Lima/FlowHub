generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model clientes {
  id                Int                 @id @default(autoincrement())
  nome              String?             @db.VarChar(100)
  numero            Int?
  endereco          String?             @db.VarChar(300)
  cpf               String?             @db.VarChar(14)
  cobranca_clientes cobranca_clientes[]
  mesas             mesas[]
}

model cobranca_clientes {
  id            Int       @id @default(autoincrement())
  cobranca_id   Int
  cliente_id    Int
  cobrado       Boolean?  @default(false)
  data_cobranca DateTime? @db.DateTime(0)
  cobrancas     cobrancas @relation(fields: [cobranca_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "cobranca_clientes_ibfk_1")
  clientes      clientes  @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "cobranca_clientes_ibfk_2")

  @@index([cliente_id], map: "cliente_id")
  @@index([cobranca_id], map: "cobranca_id")
}

model cobrancas {
  id                Int                 @id @default(autoincrement())
  nome              String              @db.VarChar(150)
  intervalo_dias    Int                 @default(30)
  data_viagem       DateTime            @db.Date
  observacoes       String?             @db.Text
  cobranca_clientes cobranca_clientes[]
}

model despesas {
  id         Int           @id @default(autoincrement())
  data_gasto DateTime      @db.Date
  origem     String        @db.VarChar(300)
  tipo       despesas_tipo
  valor      Decimal       @db.Decimal(10, 2)
  total      Decimal       @db.Decimal(10, 2)
  created_at DateTime?     @default(now()) @db.Timestamp(0)
  updated_at DateTime?     @default(now()) @db.Timestamp(0)
}

model materiais {
  id         Int              @id @default(autoincrement())
  nome       String           @db.VarChar(100)
  unidade    String           @db.VarChar(20)
  quantidade Int              @default(0)
  status     materiais_status @default(VAZIO)
  created_at DateTime?        @default(now()) @db.Timestamp(0)
  updated_at DateTime?        @default(now()) @db.Timestamp(0)
}

model mesas {
  id             Int              @id @default(autoincrement())
  cliente_id     Int
  numeracao      String           @db.VarChar(100)
  clientes       clientes         @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mesas_ibfk_1")
  registros_mesa registros_mesa[]

  @@index([cliente_id], map: "cliente_id")
}

model registros_mesa {
  id           Int      @id @default(autoincrement())
  mesa_id      Int
  data_leitura DateTime @db.Date
  leitura      Int
  deve         Decimal  @db.Decimal(10, 2)
  valor_pago   Decimal  @default(0) @db.Decimal(10, 2)
  pago         Boolean  @default(false)
  mesas        mesas    @relation(fields: [mesa_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "registros_mesa_ibfk_1")

  @@index([mesa_id], map: "mesa_id")
}

enum despesas_tipo {
  receita
  despesa
}

enum materiais_status {
  VAZIO
  BAIXO
  ALTO
}
